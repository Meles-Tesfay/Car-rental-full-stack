{
  "version": 2,
  "builds": [
    {
      "src": "server/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "server/server.js"
    },
    {
      "source": "/success",
      "destination": "/client/index.html"
    },
    {
      "source": "/cars",
      "destination": "/client/index.html"
    },
    {
      "source": "/car-details/(.*)",
      "destination": "/client/index.html"
    },
    {
      "source": "/my-bookings",
      "destination": "/client/index.html"
    },
    {
      "source": "/owner/(.*)",
      "destination": "/client/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/client/$1"
    }
  ]
}
